  "ai_architecture": {
    "layers": [
      "Observation Layer (line sensors, obstacle detection, battery)",
      "Belief Estimation (confidence, uncertainty, position tracking)",
      "Task Intent Layer (goal representation, task graph)",
      "Global Objective Function (score = coverage - cost - uncertainty - revisit + time_decay)",
      "Intelligent Node Selection (argmax expected_reward)",
      "Probabilistic FSM (softmax Q/temperature)",
      "Lightweight Prediction (sensor confidence trend monitoring)",
      "Adaptive Recovery (re-observe, re-localize, re-plan)"
    ],
    "key_innovations": [
      "Global Objective Function: unified scoring across coverage, cost, uncertainty, and novelty",
      "Intelligent Node Selection: argmax(expected_reward) for dynamic waypoint selection",
      "Predictive Recovery: triggered by confidence trend monitoring before failure",
      "Probabilistic Decision: softmax(Q/temperature) for smooth behavior transitions"
    ]
  },

  "q_learning": {
    "state_space": "3D discretized (obstacle, battery, exploration)",
