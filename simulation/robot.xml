<mujoco model="robothon_mobile_robot">
    <option timestep="0.002" gravity="0 0 -9.81">
        <flag contact="enable"/>
    </option>
    
    <default>
        <joint damping="0.5"/>
        <geom condim="4" friction="1.0 0.2 0.01"/>
    </default>
    
    <visual>
        <global offwidth="1280" offheight="720"/>
        <headlight ambient="0.6 0.6 0.6" diffuse="0.8 0.8 0.8" specular="0.3 0.3 0.3"/>
    </visual>
    
    <asset>
        <texture name="ground" type="2d" builtin="checker" rgb1="0.85 0.85 0.85" rgb2="0.65 0.65 0.65" width="512" height="512"/>
        <texture name="line" type="2d" builtin="flat" rgb1="0.1 0.1 0.1" width="64" height="64"/>
        <material name="ground_mat" texture="ground" texrepeat="8 8" specular="0.1" shininess="0.1"/>
        <material name="line_mat" texture="line" rgba="0.1 0.1 0.1 1"/>
        <material name="chassis_mat" rgba="0.2 0.4 0.9 1" specular="0.6" shininess="0.6"/>
        <material name="wheel_mat" rgba="0.2 0.2 0.2 1" specular="0.4" shininess="0.4"/>
        <material name="sensor_mat" rgba="1.0 0.3 0.3 1"/>
        <material name="top_mat" rgba="0.0 1.0 0.4 1" specular="0.6" shininess="0.6"/>
        <material name="led_mat" rgba="0.0 1.0 0.0 1"/>
        <material name="obstacle_mat" rgba="0.9 0.2 0.2 1" specular="0.3" shininess="0.3"/>
        <material name="wall_mat" rgba="0.6 0.6 0.6 1" specular="0.2" shininess="0.2"/>
    </asset>
    
    <worldbody>
        <!-- 地面 -->
        <geom name="ground" type="plane" size="3 3 0.1" material="ground_mat"/>
        
        <!-- 障碍物 - 触发 cautious/avoid 行为 -->
        <geom name="obstacle_1" type="cylinder" size="0.08 0.12" pos="0.5 0.15 0.12" material="obstacle_mat" mass="2"/>
        <geom name="obstacle_2" type="cylinder" size="0.08 0.12" pos="0.8 -0.1 0.12" material="obstacle_mat" mass="2"/>
        <geom name="obstacle_3" type="box" size="0.06 0.06 0.1" pos="0.35 -0.2 0.1" material="obstacle_mat" mass="1.5"/>
        <geom name="obstacle_4" type="cylinder" size="0.05 0.08" pos="1.0 0.2 0.08" material="obstacle_mat" mass="1"/>
        
        <!-- 边界墙 -->
        <geom name="wall_n" type="box" size="1.5 0.02 0.1" pos="0 0.48 0.1" material="wall_mat" contype="1"/>
        <geom name="wall_s" type="box" size="1.5 0.02 0.1" pos="0 -0.48 0.1" material="wall_mat" contype="1"/>
        <geom name="wall_e" type="box" size="0.02 0.5 0.1" pos="1.5 0 0.1" material="wall_mat" contype="1"/>
        
        <!-- 三摄像机系统 -->
        <camera name="global_view" pos="0 0 2.8" xyaxes="1 0 0 0 1 0" fovy="70"/>
        <camera name="main_follow" pos="1.3 -1.6 1.1" xyaxes="1 0 0 0 1 0" fovy="55"/>
        <camera name="task_view" pos="0.6 -0.8 0.9" xyaxes="1 0 0 0 1 0" fovy="50"/>
        
        <!-- 灯光 -->
        <light pos="0 0 3" dir="0 0 -1" diffuse="1 1 1" specular="0.4 0.4 0.4"/>
        <light pos="1 1 2" dir="-0.5 -0.5 -1" diffuse="0.5 0.5 0.5"/>
        <light pos="-1 1 2" dir="0.5 -0.5 -1" diffuse="0.4 0.4 0.4"/>
        
        <!-- 移动机器人 -->
        <body name="robot" pos="0 0 0.08">
            <freejoint name="robot_joint"/>
            
            <!-- 底盘主体 -->
            <geom name="chassis" type="box" size="0.15 0.1 0.04" material="chassis_mat" mass="0.5"/>
            
            <!-- 顶部绿色圆盘 -->
            <geom name="top_disk" type="cylinder" size="0.08 0.01 0" pos="0 0 0.05" material="top_mat"/>
            
            <!-- 前端LED -->
            <geom name="led_front" type="sphere" size="0.015" pos="0.15 0 0" material="led_mat"/>
            
            <!-- 后端LED -->
            <geom name="led_rear" type="sphere" size="0.015" pos="-0.15 0 0" material="led_mat"/>
            
            <!-- 左轮 -->
            <body name="left_wheel" pos="0 -0.1 -0.02">
                <joint name="left_wheel_joint" type="hinge" axis="0 1 0"/>
                <geom name="left_wheel_geom" type="cylinder" size="0.035 0.015" euler="90 0 0" material="wheel_mat" mass="0.05"/>
            </body>
            
            <!-- 右轮 -->
            <body name="right_wheel" pos="0 0.1 -0.02">
                <joint name="right_wheel_joint" type="hinge" axis="0 1 0"/>
                <geom name="right_wheel_geom" type="cylinder" size="0.035 0.015" euler="90 0 0" material="wheel_mat" mass="0.05"/>
            </body>
            
            <!-- 传感器阵列 -->
            <body name="sensor_array" pos="0.15 0 0.01">
                <geom name="sensor_0" type="cylinder" size="0.01 0.008" pos="0 -0.05 0" material="sensor_mat" contype="0" conaffinity="0"/>
                <geom name="sensor_1" type="cylinder" size="0.01 0.008" pos="0 -0.025 0" material="sensor_mat" contype="0" conaffinity="0"/>
                <geom name="sensor_2" type="cylinder" size="0.01 0.008" pos="0 0 0" material="sensor_mat" contype="0" conaffinity="0"/>
                <geom name="sensor_3" type="cylinder" size="0.01 0.008" pos="0 0.025 0" material="sensor_mat" contype="0" conaffinity="0"/>
                <geom name="sensor_4" type="cylinder" size="0.01 0.008" pos="0 0.05 0" material="sensor_mat" contype="0" conaffinity="0"/>
            </body>
        </body>
    </worldbody>
    
    <!-- 传感器 -->
    <sensor>
        <jointpos name="left_wheel_pos" joint="left_wheel_joint"/>
        <jointpos name="right_wheel_pos" joint="right_wheel_joint"/>
        <jointvel name="left_wheel_vel" joint="left_wheel_joint"/>
        <jointvel name="right_wheel_vel" joint="right_wheel_joint"/>
    </sensor>
    
    <!-- 执行器 -->
    <actuator>
        <motor name="left_motor" joint="left_wheel_joint" gear="50" ctrlrange="-10 10" ctrllimited="true"/>
        <motor name="right_motor" joint="right_wheel_joint" gear="50" ctrlrange="-10 10" ctrllimited="true"/>
    </actuator>
</mujoco>
